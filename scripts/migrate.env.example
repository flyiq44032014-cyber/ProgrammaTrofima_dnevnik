# Скопируйте в migrate.env (файл в git не попадает) и подставьте свои строки.
# Источник — локальная PostgreSQL после работы с проектом.
LOCAL_DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/имя_локальной_бд
# Назначение — внешний URL базы на Render (External Database URL), с компьютера доступен именно он.
REMOTE_DATABASE_URL=postgresql://USER:PASSWORD@dpg-xxxx.frankfurt-postgres.render.com/имя_бд
