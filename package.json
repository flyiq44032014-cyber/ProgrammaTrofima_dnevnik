{
  "name": "elektronnyj-dnevnik",
  "version": "1.0.1",
  "private": true,
  "description": "Электронный дневник — Express + TypeScript",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "postinstall": "npm run build",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "typecheck": "tsc --noEmit",
    "db:seed": "npm run build && node dist/db/seed.js",
    "db:seed:simple": "npm run build && node dist/db/seedSimple.js",
    "db:seed:demo-users": "npm run build && node dist/db/seedDemoUsers.js",
    "db:seed:surnames-400": "npm run build && node dist/db/seedStudentSurnames400.js",
    "db:seed:family-parents": "npm run build && node dist/db/seedFamilyParents.js",
    "db:backfill:parent-student-ids": "npm run build && node dist/db/backfillUserParentStudentIds.js",
    "db:backfill:student-performance": "npm run build && node dist/db/backfillStudentPerformanceFromClass.js",
    "db:backfill:finals-quarters": "npm run build && node dist/db/backfillFinalsQuarters.js",
    "db:activate:parents": "npm run build && node dist/db/activateParentAccounts.js",
    "db:activate:teachers": "npm run build && node dist/db/activateTeacherAccounts.js",
    "db:full-copy": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pg-full-copy.ps1",
    "db:copy-to-render": "node scripts/fullDbCopy.cjs",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-session": "^2.1.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.14.1"
  },
  "devDependencies": {
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.2.0",
    "supertest": "^7.0.0",
    "vitest": "^2.1.8",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-session": "^2.0.49",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
