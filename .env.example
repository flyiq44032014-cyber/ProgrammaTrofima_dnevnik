# Скопируйте в .env и подставьте строку из Neon (Dashboard → Connection string)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Чтобы при `npm run db:seed` в БД создавались демо-пользователи
# (email/пароли для проверки функционала) — включи SEED_DEMO_USERS=1.
SEED_DEMO_USERS=0

# Секрет подписи cookie сессии (в продакшене — длинная случайная строка)
SESSION_SECRET=замените-на-случайную-строку
