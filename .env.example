# Скопируйте в .env и подставьте строку из Neon (Dashboard → Connection string)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Чтобы при `npm run db:seed` в БД создавались демо-пользователи
# (email/пароли для проверки функционала) — включи SEED_DEMO_USERS=1.
SEED_DEMO_USERS=0

# Секрет подписи cookie сессии (в продакшене — длинная случайная строка)
SESSION_SECRET=замените-на-случайную-строку

# Полная копия БД на хостинг: см. scripts/migrate.env.example -> scripts/migrate.env, затем npm run db:full-copy
# LOCAL_DATABASE_URL=postgresql://...
# REMOTE_DATABASE_URL=postgresql://...
#
# Копия без pg_dump (только Node + pg): задайте LOCAL_DATABASE_URL и DATABASE_URL, затем npm run db:copy-to-render
